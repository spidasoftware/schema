meta {
  name: Save Project (POST)
  type: http
  seq: 1
}

post {
  url: {{dbBase}}/projects?apiToken={{apiToken}}
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  project: {"label":"my-project","leads":[],"locations":[]}
}

docs {
  Save a new project to SPIDAdb.

  The project parameter must be a valid SPIDAcalc project JSON.
  POST to /projects (or /projects.calc for explicit format).

  For exchange file upload, POST to /projects.exchange with multipart form.
}
