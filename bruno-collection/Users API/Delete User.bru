meta {
  name: Delete User
  type: http
  seq: 5
}

post {
  url: {{umBase}}/usersAPI/delete?apiToken={{apiToken}}
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  id: 1
}

docs {
  Deletes a user.

  Parameters:
  - id: the id of the user to delete (required)

  Returns a general response object.
}
