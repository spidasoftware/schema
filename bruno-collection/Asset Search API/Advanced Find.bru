meta {
  name: Advanced Find
  type: http
  seq: 2
}

get {
  url: {{amBase}}/assetSearchAPI/advancedFind?apiToken={{apiToken}}&find_query={}
  body: none
  auth: none
}

params:query {
  apiToken: {{apiToken}}
  find_query: {}
  ~companyId: 
}

docs {
  Find stations based on a complex query.

  Parameters:
  - find_query: a query object (required)
  - companyId: search a company other than your home company (optional)

  Use getAdvancedFindOptions to discover available query fields.
}
